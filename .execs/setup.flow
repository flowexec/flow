# yaml-language-server: $schema=https://flowexec.io/schemas/flowfile_schema.json
tags: [development, setup]
executables:
  - verb: setup
    name: dev
    description: Setup development environment
    serial:
      execs:
        - ref: install tools
        - ref: generate
        - cmd: echo "✅ flow development environment ready"

  - verb: install
    name: gopath
    aliases: [local, cli]
    description: Install the Go CLI to the GOPATH from local source
    exec:
      dir: //
      cmd: go install ./...

  - verb: start
    name: hero-recording
    description: Record the hero demo clip (full story, for README/homepage)
    tags: [vhs, demo]
    exec:
      dir: //
      cmd: vhs docs/demo/hero.tape
