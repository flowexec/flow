namespace: docs
imports:
  - package.json

executables:
  - verb: install
    description: Install documentation dependencies using the lockfile
    exec:
      dir: //docs
      cmd: npm ci

  - verb: deploy
    name: cloudflare
    description: Generate, build, and deploy documentation to Cloudflare Pages
    tags: [docs, deploy]
    exec:
      args:
          - envKey: ENVIRONMENT
            default: preview
            pos: 1
            required: false
      params:
        - envKey: CLOUDFLARE_API_TOKEN
          secretRef: flow-cloudflare-api-token
        - envKey: CLOUDFLARE_ACCOUNT_ID
          secretRef: flow-cloudflare-account-id
      cmd: |
          npm run build

          # Generate deploy message from git log
          COMMIT_SHA=$(git rev-parse --short HEAD)
          COMMIT_MSG=$(git log -1 --pretty=%s)
          BRANCH=$(git rev-parse --abbrev-ref HEAD)

          # Check if branch is dirty
          if ! git diff-index --quiet HEAD --; then
            DIRTY=" (dirty)"
          else
            DIRTY=""
          fi

          MESSAGE="${BRANCH}@${COMMIT_SHA}${DIRTY}: ${COMMIT_MSG}"

          if [ "${ENVIRONMENT}" = "production" ]; then
            npx wrangler pages deploy dist --project-name=flow-docs --branch=main --commit-message="${MESSAGE}"
          else
            npx wrangler pages deploy dist --project-name=flow-docs --branch=preview --commit-message="${MESSAGE}"
          fi

  - verb: deploy
    name: netlify
    description: (DEPRECATED) Deploy documentation to Netlify - use cloudflare instead
    tags: [docs, deploy, deprecated]
    exec:
      args:
          - envKey: ENVIRONMENT
            default: preview
            pos: 1
            required: false
      params:
        - envKey: NETLIFY_AUTH_TOKEN
          secretRef: netlify-pat
        - envKey: NETLIFY_SITE_ID
          secretRef: netlify-flow-site-id
      cmd: |
          # Generate deploy message from git log
          COMMIT_SHA=$(git rev-parse --short HEAD)
          COMMIT_MSG=$(git log -1 --pretty=%s)
          BRANCH=$(git rev-parse --abbrev-ref HEAD)

          # Check if branch is dirty
          if ! git diff-index --quiet HEAD --; then
            DIRTY=" (dirty)"
          else
            DIRTY=""
          fi

          MESSAGE="${BRANCH}@${COMMIT_SHA}${DIRTY}: ${COMMIT_MSG}"

          if [ "${ENVIRONMENT}" = "production" ]; then
            npx netlify-cli deploy --dir=dist --prod --message="${MESSAGE}"
          else
            npx netlify-cli deploy --dir=dist --message="${MESSAGE}"
          fi
