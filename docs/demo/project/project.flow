# yaml-language-server: $schema=https://flowexec.io/schemas/flowfile_schema.json
namespace: demo
visibility: public

executables:
  - verb: run
    name: greet
    tags: [text]
    description: Greet someone by name
    exec:
      params:
        - envKey: NAME
          prompt: What is your name?
        - envKey: COLOR
          prompt: What is your favorite color?
      cmd: |
        echo "Hello, $NAME!"
        echo "I like $COLOR too :)"

  - verb: build
    name: app
    tags: [ci]
    description: Build the application binary
    exec:
      cmd: |
        echo "Building app..."

  - verb: test
    name: unit
    tags: [ci]
    description: Run unit tests with coverage
    exec:
      cmd: |
        echo "Running tests..."
        echo "all passed"

  - verb: deploy
    name: staging
    description: Full deploy pipeline to staging
    tags: [deploy, ci]
    serial:
      execs:
        - name: envcheck
          cmd: |
            echo "Checking environment..."
            sleep 0.3 && echo "Go 1.25 detected"
            sleep 0.3 && echo "Dependencies up to date"
        - name: build
          cmd: |
            echo "Building application..."
            sleep 0.3 && echo "Build succeeded"
        - name: deploy
          cmd: |
            echo "Deploying to staging..."
            sleep 0.3 && echo "Staging environment ready"
            sleep 0.3 && echo "Syncing files..."
            sleep 0.3 && echo "Done"
